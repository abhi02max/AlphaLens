# ==========================================
# BACKEND ENVIRONMENT VARIABLES
# ==========================================

# 1. Server Configuration
PORT=5001
NODE_ENV=development

# 2. MongoDB Database (Required)
# Replace with your MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/alphalens?retryWrites=true&w=majority

# 3. Clerk Authentication (Required)
# Get these from your Clerk Dashboard (clerk.com)
CLERK_SECRET_KEY=sk_test_...

# 4. OpenRouter AI (Required)
# Get this from openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-...

# 5. Upstash Redis Cache (Optional - App runs without it)
# Get this from upstash.com (Redis connection string, not REST)
UPSTASH_REDIS_URL=redis://...

# 6. Resend Email (Optional - For welcome emails)
# Get this from resend.com
RESEND_API_KEY=re_...

# 7. Sentry Observability (Optional)
# Get this from sentry.io (Node project)
SENTRY_DSN=https://...